/**app.wxss**/

/* ========== 极简白色风格 ========== */

page {
  font-family: -apple-system, BlinkMacSystemFont, sans-serif;
  background-color: #FFFFFF;
}

page view, page button, page text {
  box-sizing: border-box;
}

/* ---------- 页面基础 ---------- */
.container {
  background: #FFFFFF;
  padding: 24rpx;
  min-height: 100vh;
}

/* ---------- 标题 ---------- */
.header {
  text-align: center;
  padding: 24rpx 0;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #C41E3A;
  display: block;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.version {
  font-size: 20rpx;
  color: #CCC;
  display: block;
  margin-top: 4rpx;
}

/* ---------- 按钮 ---------- */
.cast-btn, .query-btn {
  margin: 20rpx 0;
  padding: 24rpx;
  background: #C41E3A;
  color: #FFF;
  font-size: 30rpx;
  border-radius: 8rpx;
  text-align: center;
  font-weight: 600;
  letter-spacing: 2rpx;
  border: none;
}
.cast-btn::after, .query-btn::after { border: none; }

/* ---------- 卦象信息 ---------- */
.hexagram-info {
  display: flex;
  padding: 20rpx;
  margin-bottom: 20rpx;
  background: #FAFAFA;
  border-radius: 8rpx;
}

.hexagram-left { flex: 1; }
.hexagram-right { flex: 1; }

.number { font-size: 22rpx; color: #999; }
.name { font-size: 32rpx; font-weight: 700; color: #C41E3A; }
.line { font-size: 24rpx; color: #666; margin-left: 8rpx; }

.trigram-item .label { font-size: 20rpx; color: #999; display: block; }
.trigram-item .value { font-size: 22rpx; color: #333; }

/* ---------- 免责声明 ---------- */
.disclaimer-btn { text-align: center; padding: 20rpx; }
.disclaimer-text { font-size: 20rpx; color: #BBB; }

.disclaimer-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.disclaimer-content {
  background: #FFF;
  width: 80%;
  padding: 32rpx;
  border-radius: 12rpx;
}

.disclaimer-title { font-size: 32rpx; font-weight: 700; color: #333; text-align: center; display: block; margin-bottom: 20rpx; }
.disclaimer-text { font-size: 24rpx; color: #666; line-height: 1.6; display: block; margin-bottom: 16rpx; }

.disclaimer-close-btn {
  background: #C41E3A;
  color: #FFF;
  font-size: 28rpx;
  padding: 16rpx 48rpx;
  border-radius: 8rpx;
  border: none;
  display: block;
  margin: 0 auto;
}

/* ---------- 查询页面 ---------- */
.query-section {
  padding: 20rpx;
  margin-bottom: 20rpx;
  background: #FAFAFA;
  border-radius: 8rpx;
}

.input-row { display: flex; margin-bottom: 16rpx; }
.input-group { flex: 1; margin-right: 12rpx; }
.input-group .label { font-size: 22rpx; color: #666; font-weight: 500; margin-bottom: 6rpx; display: block; }

.picker {
  border: 1rpx solid #DDD;
  padding: 14rpx;
  border-radius: 6rpx;
  background: #FFF;
  font-size: 24rpx;
}