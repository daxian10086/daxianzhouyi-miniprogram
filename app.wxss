/**app.wxss**/

/* ========== 扁平简约风格 ========== */

page {
  font-family: -apple-system, BlinkMacSystemFont, sans-serif;
  background-color: #FFFFFF;
  font-size: 42rpx;
  color: #1a1a1a;
}

page view, page button, page text { box-sizing: border-box; }

/* ---------- 页面基础 ---------- */
.container {
  background: #FFFFFF;
  padding: 24rpx;
  min-height: 100vh;
}

/* ---------- 标题区域 ---------- */
.header {
  text-align: center;
  padding: 20rpx 0 16rpx;
}

.title {
  font-size: 42rpx;
  font-weight: 800;
  color: #C41E3A;
  display: block;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #999999;
  display: block;
  margin-top: 6rpx;
}

.version {
  font-size: 18rpx;
  color: #DDDDDD;
  display: block;
  margin-top: 4rpx;
}

/* ---------- 按钮 - 扁平化 ---------- */
.cast-btn,
.query-btn {
  display: block;
  width: 100%;
  margin: 16rpx 0;
  padding: 32rpx;
  background: #C41E3A;
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 700;
  border-radius: 10rpx;
  border: none;
  text-align: center;
  letter-spacing: 4rpx;
}
.cast-btn::after,
.query-btn::after { border: none; }

.query-btn {
  background: #333333;
}

/* ---------- 卦象信息 ---------- */
.hexagram-info { }
.hexagram-left { }
.hexagram-right { }
.number { }
.name-line { }
.name { }
.line { }
.trigram-item .label { }
.trigram-item .value { }

/* ---------- 免责声明 ---------- */
.disclaimer-btn {
  text-align: center;
  padding: 32rpx;
}

.disclaimer-text {
  font-size: 24rpx;
  color: #BBBBBB;
}

.disclaimer-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.disclaimer-content {
  background: #FFFFFF;
  width: 85%;
  border-radius: 16rpx;
  padding: 36rpx;
}

.disclaimer-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #1a1a1a;
  text-align: center;
  display: block;
  margin-bottom: 20rpx;
}

.disclaimer-text {
  font-size: 42rpx;
  color: #666666;
  line-height: 1.7;
  display: block;
  margin-bottom: 14rpx;
}

.disclaimer-close-btn {
  display: block;
  width: 100%;
  padding: 22rpx;
  background: #C41E3A;
  color: #FFFFFF;
  font-size: 42rpx;
  font-weight: 600;
  border-radius: 8rpx;
  border: none;
  margin-top: 28rpx;
}
.disclaimer-close-btn::after { border: none; }

/* ---------- 查询区域 ---------- */
.query-section {
  background: #FAFAFA;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #EEEEEE;
}

.input-row {
  display: flex;
  gap: 14rpx;
}

.input-group {
  flex: 1;
}

.input-group .label {
  font-size: 24rpx;
  color: #666666;
  display: block;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.picker {
  background: #FFFFFF;
  border: 1rpx solid #E0E0E0;
  border-radius: 8rpx;
  padding: 18rpx;
  font-size: 42rpx;
  color: #1a1a1a;
}

/* ---------- 摇一卦专属 ---------- */
.shake-hint-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 48rpx 0;
}

.shake-hint-card {
  text-align: center;
  background: transparent;
  padding: 40rpx;
}

.shake-icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0 auto 20rpx;
}

.shake-icon {
  font-size: 56rpx;
}

.shake-hint-title {
  font-size: 42rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
  margin-bottom: 6rpx;
}

.shake-hint-desc {
  font-size: 24rpx;
  color: #999999;
  display: block;
}

.shaking-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
}

.shaking-img {
  width: 140rpx;
  height: 140rpx;
}

.shaking-text {
  font-size: 24rpx;
  color: #666666;
  margin-top: 16rpx;
}

.shaking-text.active {
  color: #C41E3A;
  font-weight: 600;
}

/* ---------- 结果外层 ---------- */
.result {
  border: none !important;
  background: transparent !important;
  padding: 0 !important;
  margin: 0 !important;
}

.result::before,
.result::after {
  display: none !important;
}
/* ---------- 摇动动画 ---------- */
.shaking-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.shaking-img {
  width: 160rpx;
  height: 160rpx;
}

.shake-animation {
  animation: shake 0.5s ease-in-out infinite;
}

@keyframes shake {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(-15deg); }
  75% { transform: rotate(15deg); }
}
