/* app.wxss - 全局样式（简约现代风格） */

/* ---------- 全局重置与基础 ---------- */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  background-color: #F5F5F5;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

page view, page button, page text { box-sizing: border-box; }

/* ---------- 页面容器 ---------- */
.container {
  background: #FFFFFF;
  padding: 32rpx;
  min-height: 100vh;
}

/* ---------- 头部 ---------- */
.header {
  text-align: center;
  padding: 24rpx 0;
}

.title {
  font-size: 44rpx;
  font-weight: 800;
  color: #C41E3A;
  display: block;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 30rpx;
  color: #999999;
  display: block;
  margin-top: 8rpx;
}

.version {
  font-size: 20rpx;
  color: #CCCCCC;
  display: block;
  margin-top: 4rpx;
}

/* ---------- 按钮 ---------- */
.cast-btn,
.query-btn {
  display: block;
  width: 100%;
  margin: 20rpx 0;
  padding: 32rpx;
  background: linear-gradient(135deg, #C41E3A 0%, #A01830 100%);
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 700;
  border-radius: 20rpx;
  border: none;
  text-align: center;
  letter-spacing: 6rpx;
  transition: all 0.3s ease;
  box-shadow: 0 6rpx 20rpx rgba(196, 30, 58, 0.3);
}

.cast-btn::after,
.query-btn::after { border: none; }

.cast-btn[disabled],
.query-btn[disabled] {
  opacity: 0.5;
}

.query-btn {
  background: linear-gradient(135deg, #555555 0%, #444444 100%);
}

/* ---------- 副标题 ---------- */
.mid-subtitle {
  text-align: center;
  padding: 32rpx 0;
}

.mid-subtitle .subtitle {
  font-size: 32rpx;
  color: #888888;
  letter-spacing: 6rpx;
  font-weight: 500;
}

/* ---------- 摇一卦 ---------- */
.shake-hint-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
}

.shake-hint-card {
  text-align: center;
  padding: 60rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  border: 2rpx solid #E8E8E8;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.shake-icon-wrapper {
  width: 180rpx;
  height: 180rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0 auto 32rpx;
  background: linear-gradient(135deg, #FFF5F5 0%, #FFF0F0 100%);
  border-radius: 50%;
  border: 3rpx solid #FFECEC;
}

.shake-icon { font-size: 72rpx; }

.shake-hint-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.shake-hint-desc {
  font-size: 24rpx;
  color: #999999;
  display: block;
}

.shaking-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.shaking-img {
  width: 200rpx;
  height: 200rpx;
}

.shake-animation {
  /* SVG内部SMIL旋转 + CSS抖动 */
  animation: bounce 0.6s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(-8rpx); }
}

.shaking-text {
  font-size: 26rpx;
  color: #666666;
  margin-top: 16rpx;
}

.shaking-text.active {
  color: #C41E3A;
  font-weight: 600;
}

/* ---------- 结果区域（清除默认样式） ---------- */
.result {
  border: none !important;
  background: transparent !important;
  padding: 0 !important;
  margin: 0 !important;
}

.result::before,
.result::after { display: none !important; }

/* ========== 全局共享组件样式 ========== */

/* ---------- 免责声明（按钮+弹窗） ---------- */
.disclaimer-btn {
  text-align: center;
  padding: 32rpx;
}

.disclaimer-text {
  font-size: 22rpx;
  color: #AAAAAA;
}

.disclaimer-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.disclaimer-content {
  background: #FFFFFF;
  width: 85%;
  max-width: 600rpx;
  border-radius: 20rpx;
  padding: 40rpx;
}

.disclaimer-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
  text-align: center;
  display: block;
  margin-bottom: 24rpx;
}

.disclaimer-body-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
  display: block;
  margin-bottom: 16rpx;
}

.disclaimer-close-btn {
  display: block;
  width: 100%;
  padding: 24rpx;
  background: #C41E3A;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
  margin-top: 28rpx;
  text-align: center;
  letter-spacing: 2rpx;
}
.disclaimer-close-btn::after { border: none; }

/* ---------- 查询区域 ---------- */
.query-section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid #E8E8E8;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.input-row {
  display: flex;
  gap: 16rpx;
}

.input-group { flex: 1; }

.input-group .label {
  font-size: 24rpx;
  color: #666666;
  display: block;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.picker {
  background: #FFFFFF;
  border: 1rpx solid #E0E0E0;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: #333333;
}
