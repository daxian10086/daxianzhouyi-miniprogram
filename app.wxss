/* app.wxss - 易经主题全局样式 v2.0
   设计理念：传统东方美学 + 现代简约风格
   主色调：中国红 #C41E3A，搭配墨黑/金色/米白
*/

/* ========== 设计 Token ========== */
page {
  /* 色彩系统 */
  --color-primary: #C41E3A;        /* 中国红 */
  --color-primary-dark: #A01830;    /* 深红 */
  --color-primary-light: #E8434F;  /* 浅红 */
  --color-gold: #D4AF37;           /* 古铜金 */
  --color-ink: #1A1A1A;            /* 墨黑 */
  --color-ink-light: #333333;      /* 浅墨 */
  --color-cream: #F5F0E6;          /* 米白背景 */
  --color-cream-dark: #EDE7DB;     /* 深米色 */
  --color-gray-100: #F7F7F7;       /* 极浅灰 */
  --color-gray-200: #EEEEEE;       /* 卡片背景 */
  --color-gray-300: #E0E0E0;       /* 边框 */
  --color-gray-400: #CCCCCC;       /* 次要文字 */
  --color-gray-500: #999999;       /* 占位符 */
  --color-gray-600: #666666;       /* 辅助文字 */
  --color-gray-700: #444444;       /* 正文文字 */

  /* 字体系统 */
  --font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  --font-size-xs: 20rpx;
  --font-size-sm: 22rpx;
  --font-size-base: 26rpx;
  --font-size-md: 28rpx;
  --font-size-lg: 32rpx;
  --font-size-xl: 36rpx;
  --font-size-2xl: 40rpx;
  --font-size-3xl: 48rpx;

  /* 间距系统 */
  --spacing-xs: 8rpx;
  --spacing-sm: 12rpx;
  --spacing-md: 16rpx;
  --spacing-lg: 24rpx;
  --spacing-xl: 32rpx;
  --spacing-2xl: 48rpx;

  /* 圆角 */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 20rpx;
  --radius-full: 9999rpx;

  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.06);
  --shadow-md: 0 4rpx 16rpx rgba(0,0,0,0.08);
  --shadow-lg: 0 8rpx 32rpx rgba(0,0,0,0.12);
  --shadow-red: 0 4rpx 20rpx rgba(196,30,58,0.25);

  /* 动效 */
  --transition-fast: 0.15s ease;
  --transition-normal: 0.25s ease;
  --transition-slow: 0.4s ease;
}

/* ========== 全局重置 ========== */
page {
  font-family: var(--font-family);
  background-color: var(--color-cream);
  font-size: var(--font-size-md);
  color: var(--color-gray-700);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

page view, page button, page text {
  box-sizing: border-box;
}

/* ========== 页面容器 ========== */
.container {
  background: var(--color-cream);
  padding: var(--spacing-xl);
  min-height: 100vh;
}

/* ========== 头部样式 ========== */
.header {
  text-align: center;
  padding: var(--spacing-lg) 0 var(--spacing-xl);
}

.header-ornament {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-md);
  margin-bottom: var(--spacing-lg);
}

.header-ornament-line {
  width: 60rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, var(--color-gold), transparent);
}

.header-ornament-dot {
  width: 8rpx;
  height: 8rpx;
  background: var(--color-gold);
  border-radius: 50%;
}

.title {
  font-size: var(--font-size-2xl);
  font-weight: 800;
  color: var(--color-primary);
  display: block;
  letter-spacing: 6rpx;
  text-shadow: 0 2rpx 8rpx rgba(196,30,58,0.15);
}

.subtitle {
  font-size: var(--font-size-base);
  color: var(--color-gray-500);
  display: block;
  margin-top: var(--spacing-xs);
  letter-spacing: 2rpx;
}

.version {
  font-size: var(--font-size-xs);
  color: var(--color-gray-400);
  display: block;
  margin-top: var(--spacing-xs);
  letter-spacing: 1rpx;
}

/* ========== 主按钮 ========== */
.cast-btn,
.query-btn {
  display: block;
  width: 100%;
  margin: var(--spacing-lg) 0;
  padding: var(--spacing-lg) var(--spacing-xl);
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: #FFFFFF;
  font-size: var(--font-size-lg);
  font-weight: 600;
  border-radius: var(--radius-lg);
  border: none;
  text-align: center;
  letter-spacing: 4rpx;
  transition: all var(--transition-normal);
  box-shadow: var(--shadow-red);
  position: relative;
  overflow: hidden;
}

.cast-btn:active,
.query-btn:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 10rpx rgba(196,30,58,0.3);
}

.cast-btn::after,
.query-btn::after {
  border: none;
}

.cast-btn[disabled],
.query-btn[disabled] {
  opacity: 0.5;
  transform: none;
  box-shadow: none;
}

/* 次要按钮 */
.query-btn {
  background: linear-gradient(135deg, var(--color-gray-700) 0%, var(--color-ink) 100%);
  box-shadow: var(--shadow-md);
  font-size: var(--font-size-base);
}

.query-btn:active {
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

/* ========== 副标题区 ========== */
.mid-subtitle {
  text-align: center;
  padding: var(--spacing-lg) 0;
}

.mid-subtitle .subtitle {
  font-size: var(--font-size-base);
  color: var(--color-gray-500);
  letter-spacing: 4rpx;
}

/* ========== 摇卦区域 ========== */
.shake-hint-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: var(--spacing-2xl) 0;
}

.shake-hint-card {
  background: var(--color-gray-200);
  border-radius: var(--radius-xl);
  padding: var(--spacing-2xl);
  text-align: center;
  width: 100%;
  box-shadow: var(--shadow-sm);
}

.shake-icon-wrapper {
  width: 140rpx;
  height: 140rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0 auto var(--spacing-lg);
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  border-radius: 50%;
  box-shadow: var(--shadow-red);
}

.shake-icon {
  font-size: 64rpx;
}

.shake-hint-title {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--color-gray-700);
  display: block;
  margin-bottom: var(--spacing-sm);
}

.shake-hint-desc {
  font-size: var(--font-size-sm);
  color: var(--color-gray-500);
  display: block;
}

/* 摇卦动画区 */
.shaking-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-2xl) 0;
}

.shaking-img {
  width: 160rpx;
  height: 160rpx;
}

.shake-animation {
  animation: gentle-shake 0.5s ease-in-out infinite;
}

@keyframes gentle-shake {
  0%, 100% { transform: translateX(0) rotate(0deg); }
  25% { transform: translateX(-6rpx) rotate(-3deg); }
  75% { transform: translateX(6rpx) rotate(3deg); }
}

.shaking-text {
  font-size: var(--font-size-base);
  color: var(--color-gray-500);
  margin-top: var(--spacing-md);
  letter-spacing: 2rpx;
}

.shaking-text.active {
  color: var(--color-primary);
  font-weight: 600;
}

/* ========== 结果区域 ========== */
.result {
  border: none !important;
  background: transparent !important;
  padding: 0 !important;
  margin: 0 !important;
}

.result::before,
.result::after {
  display: none !important;
}

/* ========== 免责声明 ========== */
.disclaimer-btn {
  text-align: center;
  padding: var(--spacing-xl);
}

.disclaimer-text {
  font-size: var(--font-size-sm);
  color: var(--color-gray-400);
  letter-spacing: 1rpx;
}

.disclaimer-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(26, 26, 26, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  backdrop-filter: blur(4rpx);
}

.disclaimer-content {
  background: #FFFFFF;
  width: 88%;
  max-width: 640rpx;
  border-radius: var(--radius-xl);
  padding: var(--spacing-2xl);
  box-shadow: var(--shadow-lg);
}

.disclaimer-title {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--color-primary);
  text-align: center;
  display: block;
  margin-bottom: var(--spacing-lg);
  letter-spacing: 2rpx;
}

.disclaimer-body-text {
  font-size: var(--font-size-base);
  color: var(--color-gray-600);
  line-height: 1.8;
  display: block;
  margin-bottom: var(--spacing-md);
}

.disclaimer-close-btn {
  display: block;
  width: 100%;
  padding: var(--spacing-lg);
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: #FFFFFF;
  font-size: var(--font-size-base);
  font-weight: 600;
  border-radius: var(--radius-md);
  border: none;
  margin-top: var(--spacing-lg);
  text-align: center;
  letter-spacing: 2rpx;
  box-shadow: var(--shadow-red);
}

.disclaimer-close-btn::after {
  border: none;
}

/* ========== 查询区域 ========== */
.query-section {
  background: var(--color-gray-200);
  border-radius: var(--radius-lg);
  padding: var(--spacing-xl);
  margin-bottom: var(--spacing-lg);
  box-shadow: var(--shadow-sm);
}

.input-row {
  display: flex;
  gap: var(--spacing-md);
  margin-bottom: var(--spacing-lg);
}

.input-group {
  flex: 1;
}

.input-group .label {
  font-size: var(--font-size-sm);
  color: var(--color-gray-600);
  display: block;
  margin-bottom: var(--spacing-sm);
  font-weight: 500;
  letter-spacing: 1rpx;
}

.picker {
  background: #FFFFFF;
  border: 2rpx solid var(--color-gray-300);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  font-size: var(--font-size-base);
  color: var(--color-gray-700);
  transition: border-color var(--transition-fast);
}

.picker:active {
  border-color: var(--color-primary);
}

/* ========== 通用卡片 ========== */
.card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: var(--spacing-xl);
  box-shadow: var(--shadow-md);
}

.card-title {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--color-primary);
  display: block;
  margin-bottom: var(--spacing-md);
  letter-spacing: 2rpx;
}

/* ========== 分割线 ========== */
.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--color-gray-300), transparent);
  margin: var(--spacing-xl) 0;
}

/* ========== 动画 ========== */
.fade-in {
  animation: fadeIn var(--transition-slow) ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ========== 工具类 ========== */
.text-primary { color: var(--color-primary); }
.text-gold { color: var(--color-gold); }
.text-ink { color: var(--color-ink); }
.text-center { text-align: center; }
.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }
.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }
.mb-lg { margin-bottom: var(--spacing-lg); }

/* Hint 太极图样式 */
.shake-icon-img {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto var(--spacing-lg);
  display: block;
}

