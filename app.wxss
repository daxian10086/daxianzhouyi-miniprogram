/**app.wxss**/

/* ========== 适度装饰风格 ========== */

page {
  font-family: -apple-system, BlinkMacSystemFont, sans-serif;
  background-color: #FFFFFF;
  font-size: 28rpx;
  color: #1a1a1a;
}

page view, page button, page text { box-sizing: border-box; }

/* ---------- 页面基础 ---------- */
.container {
  background: #FFFFFF;
  padding: 24rpx;
  min-height: 100vh;
}

/* ---------- 标题区域 ---------- */
.header {
  text-align: center;
  padding: 24rpx 0 20rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 800;
  color: #C41E3A;
  display: block;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #999999;
  display: block;
  margin-top: 8rpx;
}

.version {
  font-size: 20rpx;
  color: #DDDDDD;
  display: block;
  margin-top: 4rpx;
}

/* ---------- 按钮 ---------- */
.cast-btn,
.query-btn {
  display: block;
  width: 100%;
  margin: 16rpx 0;
  padding: 28rpx;
  background: #C41E3A;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  text-align: center;
  letter-spacing: 2rpx;
}
.cast-btn::after,
.query-btn::after { border: none; }

.query-btn {
  background: #333333;
}

/* ---------- 卦象信息 ---------- */
.hexagram-info { }
.hexagram-left { }
.hexagram-right { }
.number { }
.name-line { }
.name { }
.line { }
.trigram-item .label { }
.trigram-item .value { }

/* ---------- 免责声明 ---------- */
.disclaimer-btn {
  text-align: center;
  padding: 32rpx;
}

.disclaimer-text {
  font-size: 22rpx;
  color: #CCCCCC;
}

.disclaimer-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.disclaimer-content {
  background: #FFFFFF;
  width: 85%;
  border-radius: 24rpx;
  padding: 40rpx;
}

.disclaimer-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  text-align: center;
  display: block;
  margin-bottom: 24rpx;
}

.disclaimer-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
  display: block;
  margin-bottom: 16rpx;
}

.disclaimer-close-btn {
  display: block;
  width: 100%;
  padding: 24rpx;
  background: #C41E3A;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
  margin-top: 32rpx;
}
.disclaimer-close-btn::after { border: none; }

/* ---------- 查询区域 ---------- */
.query-section {
  background: #FAFAFA;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.input-row {
  display: flex;
  gap: 16rpx;
}

.input-group {
  flex: 1;
}

.input-group .label {
  font-size: 22rpx;
  color: #666666;
  display: block;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.picker {
  background: #FFFFFF;
  border: 1rpx solid #E5E5E5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: #1a1a1a;
}

/* ---------- 摇一卦专属 ---------- */
.shake-hint-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 0;
}

.shake-hint-card {
  text-align: center;
}

.shake-icon-wrapper {
  width: 140rpx;
  height: 140rpx;
  background: #FFF5F5;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0 auto 20rpx;
}

.shake-icon {
  font-size: 64rpx;
}

.shake-hint-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
  margin-bottom: 8rpx;
}

.shake-hint-desc {
  font-size: 24rpx;
  color: #999999;
  display: block;
}

.shaking-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.shaking-img {
  width: 160rpx;
  height: 160rpx;
}

.shaking-text {
  font-size: 28rpx;
  color: #666666;
  margin-top: 20rpx;
}

.shaking-text.active {
  color: #C41E3A;
  font-weight: 600;
}

/* ---------- 结果外层 ---------- */
.result {
  border: none !important;
  background: transparent !important;
  padding: 0 !important;
  margin: 0 !important;
}

.result::before,
.result::after {
  display: none !important;
}