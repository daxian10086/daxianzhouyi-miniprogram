/**app.wxss**/
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
  font-weight: 400;
  color: #333;
  background-color: #F5F5F5;
}

page view {
  box-sizing: border-box;
}

page button {
  box-sizing: border-box;
}

page text {
  box-sizing: border-box;
}

/* ========== 统一共享样式 - 摇一卦和手动查询完全同步 ========== */

/* ---------- 页面基础 ---------- */
page {
  background: #F5F5F5;
}

.container {
  background: #F5F5F5;
  padding: 20rpx;
  min-height: 100vh;
}

/* ---------- 标题区域 ---------- */
.header {
  text-align: center;
  padding: 40rpx 20rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #C41E3A;
  display: block;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #8B4513;
  display: block;
  margin-bottom: 16rpx;
}

.version {
  font-size: 24rpx;
  color: #999;
  display: block;
}

/* ---------- 选项卡 ---------- */
.tabs {
  display: flex;
  margin-top: 48rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: rgba(0, 0, 0, 0.3);
  border: 1rpx solid #D4A574;
}

.tab {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  background: transparent;
  color: #5D3A1A;
  transition: all 0.3s ease;
}

.tab.active {
  background: #C41E3A;
  color: white;
  font-weight: bold;
}

.tab-content {
  margin-top: 32rpx;
}

/* ---------- 卦象详情 ---------- */
.hexagram-detail {
  padding: 24rpx;
}

.detail-item {
  margin-bottom: 24rpx;
  padding: 16rpx;
  background: white;
  border-radius: 12rpx;
}

.detail-label {
  display: block;
  font-size: 28rpx;
  color: #8B4513;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.detail-value {
  display: block;
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
}

/* ---------- 详解两列布局 ---------- */
.detail-columns {
  display: flex;
  flex-direction: row;
}

.detail-column {
  flex: 1;
  padding: 16rpx;
}

.column-title {
  display: block;
  font-size: 28rpx;
  color: #8B4513;
  font-weight: bold;
  margin-bottom: 16rpx;
  text-align: center;
}

/* ---------- 解锁区域 ---------- */
.share-blur {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
  background: rgba(255,255,255,0.9);
  border-radius: 24rpx;
  margin-top: 32rpx;
}

.blur-text {
  font-size: 36rpx;
  margin-bottom: 16rpx;
}

.blur-hint {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 32rpx;
}

.share-btn {
  background: #C41E3A;
  color: white;
  font-size: 28rpx;
  padding: 20rpx 48rpx;
  border-radius: 16rpx;
  border: none;
}

/* ---------- 按钮统一样式 ---------- */
.cast-btn,
.query-btn {
  margin: 32rpx;
  padding: 32rpx;
  background: #C41E3A;
  color: white;
  font-size: 40rpx;
  border-radius: 16rpx;
  text-align: center;
  font-weight: bold;
  letter-spacing: 6rpx;
  border: 2rpx solid #D4A574;
}

/* ---------- 卦象信息区域 ---------- */
.hexagram-info {
  display: flex;
  margin-bottom: 32rpx;
  padding: 24rpx;
  background: white;
  border-radius: 16rpx;
}

.hexagram-left {
  flex: 1;
}

.hexagram-right {
  flex: 1;
}

.number {
  font-size: 28rpx;
  color: #666;
}

.name-line {
  margin-top: 8rpx;
}

.name {
  font-size: 36rpx;
  font-weight: bold;
  color: #C41E3A;
}

.line {
  font-size: 28rpx;
  color: #8B4513;
  margin-left: 16rpx;
}

.trigram-item {
  margin-bottom: 8rpx;
}

.trigram-item .label {
  font-size: 24rpx;
  color: #999;
}

.trigram-item .value {
  font-size: 26rpx;
  color: #333;
}

/* ---------- 免责声明 ---------- */
.disclaimer-btn {
  text-align: center;
  padding: 20rpx;
}

.disclaimer-text {
  font-size: 24rpx;
  color: #999;
}

.disclaimer-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.disclaimer-content {
  background: white;
  width: 80%;
  max-width: 600rpx;
  padding: 40rpx;
  border-radius: 24rpx;
}

.disclaimer-header {
  text-align: center;
  margin-bottom: 30rpx;
}

.disclaimer-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.disclaimer-body {
  margin-bottom: 40rpx;
}

.disclaimer-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.disclaimer-footer {
  text-align: center;
}

.disclaimer-close-btn {
  background: #C41E3A;
  color: white;
  font-size: 32rpx;
  padding: 20rpx 60rpx;
  border-radius: 16rpx;
  border: none;
}

/* ---------- 查询页面专用 ---------- */
.query-section {
  margin: 32rpx;
  padding: 32rpx;
  background: white;
  border-radius: 16rpx;
}

.input-row {
  display: flex;
  margin-bottom: 24rpx;
}

.input-group {
  flex: 1;
  margin-right: 16rpx;
}

.input-group .label {
  font-size: 28rpx;
  color: #8B4513;
  font-weight: bold;
  margin-bottom: 8rpx;
  display: block;
}

.picker {
  border: 2rpx solid #ddd;
  padding: 20rpx;
  border-radius: 12rpx;
  background: white;
}
