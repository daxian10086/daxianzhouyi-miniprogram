/**app.wxss**/

/* ========== 简约有质感风格 ========== */

page {
  font-family: -apple-system, BlinkMacSystemFont, sans-serif;
  background-color: #F8F8F8;
  font-size: 28rpx;
  color: #1a1a1a;
}

page view, page button, page text { box-sizing: border-box; }

/* ---------- 页面基础 ---------- */
.container {
  background: #F8F8F8;
  padding: 24rpx;
  min-height: 100vh;
}

/* ---------- 标题区域 ---------- */
.header {
  text-align: center;
  padding: 20rpx 0 16rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 800;
  color: #C41E3A;
  display: block;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 22rpx;
  color: #999999;
  display: block;
  margin-top: 6rpx;
}

.version {
  font-size: 18rpx;
  color: #DDDDDD;
  display: block;
  margin-top: 4rpx;
}

/* ---------- 按钮 ---------- */
.cast-btn,
.query-btn {
  display: block;
  width: 100%;
  margin: 14rpx 0;
  padding: 26rpx;
  background: linear-gradient(135deg, #C41E3A 0%, #A01830 100%);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  text-align: center;
  letter-spacing: 2rpx;
  box-shadow: 0 4rpx 16rpx rgba(196, 30, 58, 0.25);
}
.cast-btn::after,
.query-btn::after { border: none; }

.query-btn {
  background: linear-gradient(135deg, #333333 0%, #1a1a1a 100%);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

/* ---------- 卦象信息 ---------- */
.hexagram-info { }
.hexagram-left { }
.hexagram-right { }
.number { }
.name-line { }
.name { }
.line { }
.trigram-item .label { }
.trigram-item .value { }

/* ---------- 免责声明 ---------- */
.disclaimer-btn {
  text-align: center;
  padding: 32rpx;
}

.disclaimer-text {
  font-size: 20rpx;
  color: #BBBBBB;
}

.disclaimer-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.disclaimer-content {
  background: #FFFFFF;
  width: 85%;
  border-radius: 24rpx;
  padding: 36rpx;
}

.disclaimer-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  text-align: center;
  display: block;
  margin-bottom: 20rpx;
}

.disclaimer-text {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.7;
  display: block;
  margin-bottom: 14rpx;
}

.disclaimer-close-btn {
  display: block;
  width: 100%;
  padding: 22rpx;
  background: linear-gradient(135deg, #C41E3A 0%, #A01830 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 14rpx;
  border: none;
  margin-top: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(196, 30, 58, 0.25);
}
.disclaimer-close-btn::after { border: none; }

/* ---------- 查询区域 ---------- */
.query-section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #F0F0F0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}

.input-row {
  display: flex;
  gap: 14rpx;
}

.input-group {
  flex: 1;
}

.input-group .label {
  font-size: 22rpx;
  color: #666666;
  display: block;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.picker {
  background: #F8F8F8;
  border: 1rpx solid #E8E8E8;
  border-radius: 12rpx;
  padding: 18rpx;
  font-size: 24rpx;
  color: #1a1a1a;
}

/* ---------- 摇一卦专属 ---------- */
.shake-hint-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 48rpx 0;
}

.shake-hint-card {
  text-align: center;
  background: #FFFFFF;
  padding: 40rpx 48rpx;
  border-radius: 24rpx;
  border: 1rpx solid #F0F0F0;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.shake-icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #FFF5F5 0%, #FFE5E5 100%);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0 auto 20rpx;
}

.shake-icon {
  font-size: 56rpx;
}

.shake-hint-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
  margin-bottom: 6rpx;
}

.shake-hint-desc {
  font-size: 22rpx;
  color: #999999;
  display: block;
}

.shaking-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
}

.shaking-img {
  width: 140rpx;
  height: 140rpx;
}

.shaking-text {
  font-size: 26rpx;
  color: #666666;
  margin-top: 16rpx;
}

.shaking-text.active {
  color: #C41E3A;
  font-weight: 600;
}

/* ---------- 结果外层 ---------- */
.result {
  border: none !important;
  background: transparent !important;
  padding: 0 !important;
  margin: 0 !important;
}

.result::before,
.result::after {
  display: none !important;
}