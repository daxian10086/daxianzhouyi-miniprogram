.disclaimer-body 





/* 摇动手机提示弹窗 */
.shake-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;
}

.shake-modal-content {
  background: white;
  border-radius: 32rpx;
  padding: 64rpx 48rpx;
  margin: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  max-width: 600rpx;
}

.shake-modal-icon {
  font-size: 80rpx;
  margin-bottom: 32rpx;
}

.shake-modal-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 24rpx;
}

.shake-modal-desc {
  font-size: 30rpx;
  color: #666;
  text-align: center;
  margin-bottom: 48rpx;
  line-height: 1.6;
}

.shake-modal-animation {
  margin-bottom: 48rpx;
}

.phone-icon {
  font-size: 100rpx;
  animation: phoneShake 0.8s ease-in-out infinite;
  display: inline-block;
}

@keyframes phoneShake {
  0%, 100% { transform: rotate(0deg) translateX(0); }
  20% { transform: rotate(-15deg) translateX(-20rpx); }
  40% { transform: rotate(15deg) translateX(20rpx); }
  60% { transform: rotate(-15deg) translateX(-20rpx); }
  80% { transform: rotate(15deg) translateX(20rpx); }
}

.shake-modal-btn {
  background: #8B4513;
  color: white;
  font-size: 36rpx;
  padding: 28rpx 64rpx;
  border-radius: 16rpx;
  font-weight: bold;
}

/* 摇动手机大提示（主界面显示） */
.shake-hint-large {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #C41E3A;
  border-radius: 32rpx;
  margin: 48rpx 32rpx;
  padding: 64rpx 48rpx;
  border: 4rpx solid #8B4513;
  
}

.shake-icon-large {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  animation: pulseIcon 1.5s ease-in-out infinite;
}

@keyframes pulseIcon {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.1); opacity: 0.8; }
}

.shake-hint-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 16rpx;
  text-align: center;
}

.shake-hint-desc {
  font-size: 30rpx;
  color: #666;
  text-align: center;
  margin-bottom: 48rpx;
}

.shake-animation {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  height: 120rpx;
  width: 200rpx;
}

.shake-hand {
  font-size: 60rpx;
  position: absolute;
  left: 0;
  animation: handMove 1s ease-in-out infinite;
  z-index: 2;
}

.shake-phone {
  font-size: 80rpx;
  position: absolute;
  right: 0;
  animation: phoneShakeLarge 0.8s ease-in-out infinite;
  z-index: 1;
}

@keyframes handMove {
  0%, 100% { transform: translateX(0) rotate(0deg); }
  25% { transform: translateX(30rpx) rotate(-20deg); }
  50% { transform: translateX(0) rotate(0deg); }
  75% { transform: translateX(30rpx) rotate(-20deg); }
}

@keyframes phoneShakeLarge {
  0%, 100% { transform: rotate(0deg) translateX(0); }
  20% { transform: rotate(-20deg) translateX(-10rpx); }
  40% { transform: rotate(20deg) translateX(10rpx); }
  60% { transform: rotate(-20deg) translateX(-10rpx); }
  80% { transform: rotate(20deg) translateX(10rpx); }
}

