}

.fortune-label {
  font-size: 32rpx;
  font-weight: bold;
  color: #8B4513;
  display: block;
  margin-bottom: 16rpx;
}

.fortune-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
