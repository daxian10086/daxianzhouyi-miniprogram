









.shaking-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  min-height: 500rpx;
  min-width: 100%;
  margin-top: 50rpx;
  overflow: visible;
  position: relative;
}

.shaking-img {
  width: 4000rpx;
  height: auto;
  /* 摇动动画 */
  animation: shake 0.5s ease-in-out infinite;
  will-change: transform;
}

.shaking-text {
  font-size: 48rpx;
  color: #8B4513;
  font-weight: bold;
  margin-top: 32rpx;
}

.shaking-text.active {
  animation: blink 0.3s ease-in-out infinite;
  will-change: opacity;
}

@keyframes shake {
  0%, 100% { transform: rotate(-15deg); }
  50% { transform: rotate(15deg); }
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}





.query-nav {
  margin: 32rpx;
  display: block;
}



.result {
  margin-top: 48rpx;
  padding: 40rpx;
  background: #C41E3A;
  border-radius: 24rpx;
  border: 2rpx solid #D4A574;
  
}



.hexagram-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.hexagram-left .number {
  font-size: 30rpx;
