/* pages/query/query.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 查询输入区 */
.query-section {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.input-group {
  margin-bottom: 30rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  display: block;
  font-weight: bold;
}

.input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background-color: #fafafa;
}

.picker {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background-color: #fafafa;
  display: flex;
  align-items: center;
}

.button-group {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.query-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
}

.query-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.query-btn.secondary {
  background-color: #f0f0f0;
  color: #333;
}

/* 查询结果区 */
.result-section {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.hexagram-header {
  text-align: center;
  padding-bottom: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}

.hexagram-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.hexagram-symbol {
  font-size: 48rpx;
  color: #666;
  display: block;
}

/* 选项卡 */
.tabs {
  display: flex;
  border-bottom: 2rpx solid #f0f0f0;
  margin-bottom: 30rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab.active {
  color: #667eea;
  font-weight: bold;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 0;
  right: 0;
  height: 4rpx;
  background-color: #667eea;
  border-radius: 2rpx;
}

/* 内容区 */
.content-area {
  min-height: 400rpx;
}

.detail-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.item-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.item-value {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  display: block;
}

/* 运势分析 */
.fortune-section {
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #f0f0f0;
}

.fortune-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 20rpx;
}

/* 爻位内容 */
.yao-content {
  padding: 20rpx 0;
}

.yao-info {
  margin-bottom: 30rpx;
}

.yao-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 15rpx;
}

.yao-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  display: block;
  padding-left: 20rpx;
}

.yao-xiang {
  margin-top: 20rpx;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 10rpx;
}

.xiang-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #667eea;
}

.xiang-value {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-left: 10rpx;
}

/* 爻位选择器 */
.yao-selector {
  padding: 10rpx 0;
}

.yao-item {
  padding: 20rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 10rpx;
  margin-bottom: 15rpx;
  background-color: #fafafa;
}

.yao-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.yao-preview {
  font-size: 24rpx;
  color: #999;
  display: block;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
