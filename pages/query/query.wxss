}

.fortune-card {
  background: #FAFAFA;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #DDD;
  /* 优化渲染性能 */
  will-change: auto;
  transform: translateZ(0);
}

.fortune-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 16rpx;
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 0;
  /* 优化点击性能 */
