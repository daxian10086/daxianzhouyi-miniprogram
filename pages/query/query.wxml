<view class="container">
  <!-- 标题 -->
  <view class="header">
    <text class="title">大仙周易</text>
    <text class="subtitle">手动查询</text>
    <text class="version">{{version}}</text>
  </view>

  <!-- 查询输入 -->
  <view class="query-section">
    <view class="input-row">
      <view class="input-group">
        <view class="label">选择卦象</view>
        <picker bindchange="onGuaChange" value="{{guaIndex}}" range="{{guaOptions}}" range-key="label">
          <view class="picker">{{guaOptions[guaIndex].label}}</view>
        </picker>
      </view>
      <view class="input-group">
        <view class="label">选择爻位</view>
        <picker bindchange="onYaoChange" value="{{yaoIndex}}" range="{{yaoOptions}}" range-key="label">
          <view class="picker">{{yaoOptions[yaoIndex].label}}</view>
        </picker>
      </view>
    </view>
    <button class="cast-btn" bindtap="onQuery">查询</button>
  </view>

  <!-- 免责声明 -->
  <view class="disclaimer-btn" bindtap="showDisclaimer"><text class="disclaimer-text">⚠️ 免责声明</text></view>

  <!-- 结果 - 完整使用共享组件 -->
  <view class="result" wx:if="{{hexagram}}">
    <shared-result 
      hexagram="{{hexagram}}"
      fortuneAnalysis="{{fortuneAnalysis}}"
      mainFortune="{{mainFortune}}"
      hasShared="{{hasShared}}"
      currentTab="{{currentTab}}"
      bind:tabchange="onTabChange"
      bind:unlock="handleWaitUnlock"
    />
  </view>
</view>

<!-- 免责声明弹窗 -->
<view class="disclaimer-modal" wx:if="{{showDisclaimerModal}}">
  <view class="disclaimer-content">
    <view class="disclaimer-header"><text class="disclaimer-title">免责声明</text></view>
    <view class="disclaimer-body">
      <text class="disclaimer-text">本小程序仅供娱乐参考，周易占卜属于传统文化内容，请勿过度迷信。</text>
      <text class="disclaimer-text">人生掌握在自己手中，命运可以通过努力改变。如遇重大决策，请理性思考，咨询专业人士。</text>
      <text class="disclaimer-text">本小程序不承担任何因使用本服务而产生的后果。</text>
    </view>
    <view class="disclaimer-footer"><button class="disclaimer-close-btn" bindtap="hideDisclaimer">我已知晓</button></view>
  </view>
</view>