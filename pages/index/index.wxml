<view class="container">
  <!-- 标题区域 -->
  <view class="header">
    <text class="title">大仙周易</text>
    <text class="subtitle">默念所想之事，心诚则灵</text>
    <text class="version">v2.3.50</text>
  </view>

  <!-- 步骤1: 摇动手机开始算卦提示 -->
  <view class="shake-hint-large" wx:if="{{showShakeHint && !isShaking && !isAnimating}}">
    <view class="shake-icon-large">📳</view>
    <text class="shake-hint-title">摇动手机开始算卦</text>
    <text class="shake-hint-desc">像摇骰子一样上下左右摇晃手机</text>
  </view>

  <!-- 步骤2: 正在摇卦动画（用户摇动时显示） -->
  <view class="shaking-area" wx:if="{{isShaking}}">
    <image class="shaking-img shake-animation" src="/assets/shaking.png" mode="widthFix"></image>
    <view class="shaking-text active">正在摇卦...</view>
  </view>

  <!-- 步骤3: 算卦中动画（停止摇动后显示2秒） -->
  <view class="shaking-area" wx:if="{{isAnimating && !isShaking}}">
    <image class="shaking-img shake-animation" src="/assets/shaking.png" mode="widthFix"></image>
    <view class="shaking-text active">算卦中...</view>
  </view>

  <!-- 摇卦按钮 -->
  <button class="cast-btn" bindtap="castHexagram" disabled="{{isAnimating || showShakeHint || isShaking}}">
    算一卦
  </button>

  <!-- 免责声明按钮 -->
  <view class="disclaimer-btn" bindtap="showDisclaimer">
    <text class="disclaimer-text">⚠️ 免责声明</text>
  </view>

  <!-- 结果区域 -->
  <view class="result" wx:if="{{hexagram}}">
    <!-- 卦象信息 -->
    <view class="hexagram-info">
      <view class="hexagram-left">
        <text class="number">第{{hexagram.number}}卦</text>
        <view class="name-line">
          <text class="name">{{hexagram.name}}</text>
          <text class="line">{{hexagram.selectedLineName}}</text>
        </view>
      </view>

      <view class="hexagram-right">
        <view class="trigram-item">
          <text class="label">上卦</text>
          <text class="value">{{hexagram.upperTrigram.symbol}} {{hexagram.upperTrigram.name}}（{{hexagram.upperTrigram.nature}}）</text>
        </view>
        <view class="trigram-item">
          <text class="label">下卦</text>
          <text class="value">{{hexagram.lowerTrigram.symbol}} {{hexagram.lowerTrigram.name}}（{{hexagram.lowerTrigram.nature}}）</text>
        </view>
      </view>
    </view>

    <!-- 选项卡 -->
    <view class="tabs">
      <view class="tab {{currentTab == 0 ? 'active' : ''}}" bindtap="switchTab" data-index="0">
        主卦
      </view>
      <view class="tab {{currentTab == 1 ? 'active' : ''}}" bindtap="switchTab" data-index="1">
        选中爻
      </view>
      <view class="tab {{currentTab == 2 ? 'active' : ''}}" bindtap="switchTab" data-index="2">
        详解
      </view>
      <view class="tab {{currentTab == 3 ? 'active' : ''}}" bindtap="switchTab" data-index="3">
        其他爻
      </view>
    </view>

    <!-- 主卦（第一个标签） -->
    <view class="tab-content" wx:if="{{currentTab == 0}}">
      <view class="hexagram-detail" wx:if="{{hexagram}}">
        <view class="detail-item" wx:if="{{hexagram.guaCi}}">
          <text class="detail-label">卦辞</text>
          <text class="detail-value">{{hexagram.guaCi}}</text>
        </view>
        <view class="detail-item" wx:if="{{hexagram.tuanZhuan}}">
          <text class="detail-label">彖传</text>
          <text class="detail-value">{{hexagram.tuanZhuan}}</text>
        </view>
        <view class="detail-item" wx:if="{{hexagram.xiangZhuan}}">
          <text class="detail-label">象传</text>
          <text class="detail-value">{{hexagram.xiangZhuan}}</text>
        </view>
        <view class="detail-item" wx:if="{{hexagram.xuGua}}">
          <text class="detail-label">序卦</text>
          <text class="detail-value">{{hexagram.xuGua}}</text>
        </view>
        <view class="detail-item" wx:if="{{hexagram.zaGua}}">
          <text class="detail-label">杂卦</text>
          <text class="detail-value">{{hexagram.zaGua}}</text>
        </view>
        <view class="detail-item" wx:if="{{hexagram.overallMeaning}}">
          <text class="detail-label">卦象含义</text>
          <text class="detail-value">{{hexagram.overallMeaning}}</text>
        </view>
      </view>
    </view>

    <!-- 选中爻（第二个标签） -->
    <view class="tab-content" wx:if="{{currentTab == 1}}">
      <view class="hexagram-detail" wx:if="{{hexagram}}">
        <view class="detail-item" wx:if="{{hexagram.selectedLineName}}">
          <text class="line" style="display: block; color: #8B4513; font-weight: bold;">{{hexagram.selectedLineName}}</text>
        </view>
        <view class="detail-item" wx:if="{{hexagram.selectedLineText}}">
          <text class="detail-label">爻辞</text>
          <text class="detail-value">{{hexagram.selectedLineText}}</text>
        </view>
        <view class="detail-item" wx:if="{{hexagram.selectedLineDesc}}">
          <text class="detail-label">象曰</text>
          <text class="detail-value">{{hexagram.selectedLineDesc}}</text>
        </view>
      </view>
    </view>

    <!-- 详解（第三个标签） -->
    <view class="tab-content" wx:if="{{currentTab == 2}}">
      <view class="fortune-detail" wx:if="{{hasShared}}">
        <view class="fortune-item">
          <text class="fortune-label">运势</text>
          <text class="fortune-text">{{fortuneAnalysis.yunshi}}</text>
        </view>
        <view class="fortune-item">
          <text class="fortune-label">财运</text>
          <text class="fortune-text">{{fortuneAnalysis.caiyun}}</text>
        </view>
        <view class="fortune-item">
          <text class="fortune-label">家庭</text>
          <text class="fortune-text">{{fortuneAnalysis.jiating}}</text>
        </view>
        <view class="fortune-item">
          <text class="fortune-label">健康</text>
          <text class="fortune-text">{{fortuneAnalysis.jiankang}}</text>
        </view>
      </view>
      <view class="share-blur" wx:else>
        <text class="blur-text">🔒 内容已隐藏</text>
        <text class="blur-hint">观看广告即可查看运势详解</text>
        <button class="share-btn" bindtap="handleWaitUnlock">立即解锁</button>
      </view>
    </view>

    <!-- 其他爻（第四个标签） -->
    <view class="tab-content" wx:if="{{currentTab == 3}}">
      <view class="line-item" wx:for="{{hexagram.lines}}" wx:key="index" wx:if="{{hasShared}}">
        <text class="line-name">{{item.name}}：{{item.text}}</text>
        <text class="line-desc">{{item.desc}}</text>
      </view>
      <view class="share-blur" wx:if="{{!hasShared}}">
        <text class="blur-text">🔒 内容已隐藏</text>
        <text class="blur-hint">观看广告即可查看运势详解</text>
        <button class="share-btn" bindtap="handleWaitUnlock">立即解锁</button>
      </view>
    </view>
  </view>
</view>

<!-- 免责声明弹窗 -->
<view class="disclaimer-modal" wx:if="{{showDisclaimerModal}}">
  <view class="disclaimer-content">
    <view class="disclaimer-header">
      <text class="disclaimer-title">免责声明</text>
    </view>
    <view class="disclaimer-body">
      <text class="disclaimer-text">
        本小程序仅供娱乐参考，周易占卜属于传统文化内容，请勿过度迷信。
      </text>
      <text class="disclaimer-text">
        人生掌握在自己手中，命运可以通过努力改变。如遇重大决策，请理性思考，咨询专业人士。
      </text>
      <text class="disclaimer-text">
        本小程序不承担任何因使用本服务而产生的后果。
      </text>
    </view>
    <view class="disclaimer-footer">
      <button class="disclaimer-close-btn" bindtap="hideDisclaimer">我已知晓</button>
    </view>
  </view>
</view>
