/* 传统典雅风格 - 古典周易主题 */

/* ========== 基础容器 ========== */


/* 古典纹理背景 */
.container

/* ========== 标题区域 ========== */


/* 古典装饰线上 */
.header::before {
  content: '';
  width: 200rpx;
  height: 4rpx;
  background: #C41E3A;
  margin-bottom: 24rpx;
}







/* ========== 摇动提示区域 ========== */
.shake-hint-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 360rpx;
  margin-top: 40rpx;
  padding: 0 40rpx;
  position: relative;
  z-index: 1;
}

.shake-hint-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  max-width: 600rpx;
  padding: 60rpx 40rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  border: 2rpx solid #D4A574;
  
}

.shake-icon-wrapper {
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #8B4513;
  border-radius: 50%;
  
}

.shake-icon {
  font-size: 80rpx;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 0.8; }
  50% { transform: scale(1.15); opacity: 1; }
}

.shake-hint-title {
  font-size: 40rpx;
  color: #8B4513;
  font-weight: bold;
  margin-top: 32rpx;
  letter-spacing: 4rpx;
}

.shake-hint-desc {
  font-size: 26rpx;
  color: #A0826D;
  margin-top: 16rpx;
  text-align: center;
  line-height: 1.5;
}

/* ========== 摇动动画区域 ========== */
.shaking-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  min-height: 500rpx;
  min-width: 100%;
  margin-top: 50rpx;
  overflow: visible;
  position: relative;
  z-index: 1;
}

.shaking-img {
  width: 300rpx;
  height: auto;
  animation: shake 0.5s ease-in-out infinite;
  will-change: transform;
  filter: drop-shadow(4rpx 4rpx 8rpx rgba(139, 69, 19, 0.3));
}

.shaking-text {
  font-size: 48rpx;
  color: #8B4513;
  font-weight: bold;
  margin-top: 32rpx;
  letter-spacing: 4rpx;
}

.shaking-text.active {
  animation: blink 0.3s ease-in-out infinite;
  will-change: opacity;
}

@keyframes shake {
  0%, 100% { transform: rotate(-15deg); }
  50% { transform: rotate(15deg); }
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

/* ========== 按钮区域 - 晋卦理念：上离下坤 ☲ ========== */


/* 丝绸般的高光 */








/* 边框高光 */




/* 免责声明按钮 */




/* ========== 结果区域 ========== */
.result {
  margin-top: 48rpx;
  padding: 40rpx;
  background: #F5E6D3;
  border-radius: 24rpx;
  border: 2rpx solid #D4A574;
  
  position: relative;
  z-index: 1;
}

/* 古典角落装饰 */
.result::before,
.result::after {
  content: '❖';
  position: absolute;
  font-size: 32rpx;
  color: #D4A574;
}

.result::before {
  top: 12rpx;
  left: 12rpx;
}

.result::after {
  bottom: 12rpx;
  right: 12rpx;
}

/* ========== 卦象信息区域 ========== */


/* 分割线 */
.hexagram-info::after {
  content: '';
  position: absolute;
  top: 0;
  bottom: 0;
  left: 50%;
  width: 2rpx;
  background: #D4A574;
}

.hexagram-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.hexagram-left .number {
  font-size: 28rpx;
  color: #5D3A1A;
  font-weight: bold;
}

.hexagram-left .name-line {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-top: 24rpx;
}

.hexagram-left .name {
  font-size: 64rpx;
  font-weight: bold;
  color: #E74C3C;
  text-shadow: 2rpx 2rpx 4rpx rgba(231, 76, 60, 0.3);
}

.hexagram-left .line {
  font-size: 32rpx;
  color: #5D3A1A;
  font-weight: bold;
}

.hexagram-right {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  flex: 1;
  align-items: center;
}

.trigram-item {
  padding: 12rpx;
  width: 100%;
  box-sizing: border-box;
  background: rgba(212, 165, 116, 0.1);
  border-radius: 8rpx;
  border-left: 3rpx solid #D4A574;
}

.trigram-item .label {
  font-size: 24rpx;
  color: #D4A574;
  display: block;
  margin-bottom: 6rpx;
  text-align: left;
  font-weight: bold;
}

.trigram-item .value {
  font-size: 28rpx;
  color: #5D4037;
  display: block;
  line-height: 1.4;
  text-align: left;
}

/* ========== 卦象含义 ========== */
.meaning {
  margin-top: 32rpx;
  padding: 24rpx;
  background: rgba(212, 165, 116, 0.08);
  border-radius: 12rpx;
  border-left: 4rpx solid #C41E3A;
}

.meaning .label {
  font-size: 26rpx;
  color: #5D3A1A;
  display: block;
  margin-bottom: 12rpx;
  font-weight: bold;
}

.meaning .value {
  font-size: 30rpx;
  color: #5D4037;
  line-height: 1.6;
}

/* ========== 选项卡 ========== */
.tabs {
  display: flex;
  margin-top: 48rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: rgba(0, 0, 0, 0.3);
  border: 1rpx solid #D4A574;
}

.tab {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  background: transparent;
  color: #5D3A1A;
  transition: all 0.3s ease;
}

.tab.active {
  background: #C41E3A;
  color: white;
  font-weight: bold;
}

.tab-content {
  margin-top: 32rpx;
}

/* ========== 爻位详情 ========== */
.line-item {
  margin-bottom: 40rpx;
  padding-bottom: 40rpx;
  border-bottom: 2rpx dashed rgba(212, 165, 116, 0.3);
}

.line-item:last-child {
  border-bottom: none;
}

.line-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #5D3A1A;
  display: block;
  margin-bottom: 12rpx;
  padding-left: 16rpx;
  border-left: 4rpx solid #C41E3A;
}

.line-desc {
  font-size: 28rpx;
  color: #5D4037;
  line-height: 1.6;
}

/* ========== 选中的爻 ========== */
.selected-line {
  background: #C41E3A;
  padding: 32rpx;
  border-radius: 16rpx;
  border: 2rpx solid #C41E3A;
}

.selected-line .content {
  font-size: 30rpx;
  color: #5D4037;
  line-height: 1.6;
  display: block;
  margin-bottom: 16rpx;
}

.selected-line .desc {
  font-size: 28rpx;
  color: #D4A574;
  line-height: 1.6;
  font-style: italic;
}

/* ========== 主卦详解 ========== */
.main-fortune {
  margin-top: 32rpx;
  padding: 24rpx;
  background: rgba(212, 165, 116, 0.05);
  border-radius: 12rpx;
  border: 1rpx solid rgba(212, 165, 116, 0.3);
}

.detail-item {
  margin-bottom: 24rpx;
}

.detail-item:last-child {
  margin-bottom: 0;
}

.detail-item .label {
  font-size: 26rpx;
  color: #D4A574;
  display: block;
  margin-bottom: 8rpx;
  font-weight: bold;
}

.detail-item .value {
  font-size: 28rpx;
  color: #5D4037;
  line-height: 1.6;
  display: block;
}

/* ========== 详细列 ========== */
.detail-columns {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.detail-column {
  flex: 1;
  min-width: 0;
  margin-top: 32rpx;
}

.column-title {
  font-size: 30rpx;
  color: #5D3A1A;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #8B4513;
  letter-spacing: 2rpx;
}

.hexagram-detail {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* ========== 详细列左 ========== */
.detail-column-left {
  padding-right: 20rpx;
}

.detail-column-left .column-title {
  text-align: left;
}

/* ========== 详细列右 ========== */
.detail-column-right {
  padding-left: 20rpx;
  border-left: 2rpx solid rgba(212, 165, 116, 0.3);
}

.detail-column-right .column-title {
  text-align: right;
}

/* ========== 详细行 ========== */
.detail-row {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

/* ========== 详细标签 ========== */
.detail-label {
  font-size: 24rpx;
  color: #5D3A1A;
  display: inline-block;
  padding: 4rpx 12rpx;
  background: rgba(196, 30, 58, 0.2);
  border-radius: 6rpx;
  margin-right: 8rpx;
}

.detail-value {
  font-size: 26rpx;
  color: #5D4037;
  line-height: 1.6;
  display: block;
}

/* ========== 二列布局 ========== */
.two-column {
  display: flex;
  flex-direction: row;
  gap: 0;
}

/* ========== 运势分析 ========== */
.fortune-section {
  margin-top: 24rpx;
}

.section-title {
  font-size: 30rpx;
  color: #8B4513;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.fortune-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
}

.fortune-item {
  width: calc(50% - 8rpx);
  padding: 20rpx;
  background: rgba(139, 69, 19, 0.05);
  border-radius: 12rpx;
  border: 1rpx solid #E8DCC8;
}

.fortune-item .item-label {
  font-size: 24rpx;
  color: #8B4513;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.fortune-item .item-value {
  font-size: 26rpx;
  color: #5D4037;
  line-height: 1.5;
  display: block;
}

/* ========== 卦辞区域 ========== */
.gua-ci-section {
  margin-top: 32rpx;
  padding: 24rpx;
  background: rgba(139, 69, 19, 0.05);
  border-radius: 12rpx;
  border: 1rpx solid #D4A574;
}

.gua-ci-title {
  font-size: 28rpx;
  color: #8B4513;
  font-weight: bold;
  display: block;
  margin-bottom: 12rpx;
}

.gua-ci-text {
  font-size: 30rpx;
  color: #5D4037;
  line-height: 1.8;
  display: block;
}

/* ========== 序卦杂卦 ========== */
.xu-za-section {
  margin-top: 24rpx;
  padding: 20rpx;
  background: rgba(139, 69, 19, 0.03);
  border-radius: 8rpx;
  border-left: 4rpx solid #D4A574;
}

.xu-za-title {
  font-size: 26rpx;
  color: #8B4513;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.xu-za-text {
  font-size: 26rpx;
  color: #5D4037;
  line-height: 1.6;
  display: block;
}

/* ========== 其他样式 ========== */
.tabs-scroll {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.tab-content-wrapper {
  padding: 20rpx 0;
}

/* ========== 响应式调整 ========== */
@media (screen height > 800rpx) {
  .shaking-area {
    min-height: 600rpx;
  }
  
  
}

/* ========== 动画优化 ========== */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.result {
  animation: fadeIn 0.5s ease-out;
}

/* ========== 按钮点击效果 ========== */


/* ========== 解锁区域样式 ========== */
.share-blur {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  background: #C41E3A;
  border-radius: 16rpx;
  border: 2rpx solid #D4A574;
  margin-top: 24rpx;
}

.blur-text {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.blur-hint {
  font-size: 26rpx;
  color: #8B4513;
  text-align: center;
  margin-bottom: 32rpx;
  line-height: 1.5;
}

.share-btn {
  padding: 24rpx 60rpx;
  background: #8B4513;
  color: white;
  font-size: 32rpx;
  border-radius: 12rpx;
  border: none;
  
  letter-spacing: 4rpx;
  font-weight: bold;
}

.share-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: #C41E3A;
  border-radius: 12rpx 12rpx 0 0;
  pointer-events: none;
}

.share-btn:active {
  transform: scale(0.96);
  
}
