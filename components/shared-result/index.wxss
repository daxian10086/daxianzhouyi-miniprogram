/* components/shared-result/index.wxss - 共享结果组件 v2.0 */

.shared-result {
  width: 100%;
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ---- 卦象信息卡片 ---- */
.hexagram-info {
  display: flex;
  justify-content: center;
  align-items: stretch;
  gap: 48rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  position: relative;
  overflow: hidden;
}

.hexagram-info::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, var(--color-primary, #C41E3A), var(--color-gold, #D4AF37));
}

.hexagram-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-right: 48rpx;
  border-right: 1rpx solid #F0F0F0;
}

.hexagram-right {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 16rpx;
}

.trigram-item:first-child {
  margin-bottom: 8rpx;
}

.number {
  font-size: 22rpx;
  color: #AAAAAA;
  display: block;
  margin-bottom: 6rpx;
  letter-spacing: 1rpx;
}

.name {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--color-primary, #C41E3A);
  display: inline;
  letter-spacing: 4rpx;
  line-height: 1.1;
}

.symbol {
  font-size: 56rpx;
  color: #1A1A1A;
  margin-left: 8rpx;
  display: inline;
  line-height: 1.1;
}

.line-name {
  font-size: 24rpx;
  color: #888888;
  display: block;
  margin-top: 8rpx;
  letter-spacing: 1rpx;
}

.trigram-label {
  font-size: 20rpx;
  color: #BBBBBB;
  display: block;
  margin-bottom: 2rpx;
  letter-spacing: 1rpx;
}

.trigram-value {
  font-size: 28rpx;
  color: #333333;
  display: block;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* ---- 选项卡 ---- */
.tabs {
  display: flex;
  margin-bottom: 20rpx;
  background: #F5F5F5;
  border-radius: 14rpx;
  padding: 6rpx;
  position: relative;
}

.tab {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666666;
  background: transparent;
  font-weight: 500;
  border-radius: 10rpx;
  transition: all 0.2s ease;
  position: relative;
  z-index: 1;
}

.tab.active {
  background: #FFFFFF;
  color: var(--color-primary, #C41E3A);
  font-weight: 700;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

.tab:active {
  opacity: 0.8;
}

/* ---- 详情列表 ---- */
.hexagram-detail {
  padding: 0;
}

.detail-item {
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: #FFFFFF;
  border-radius: 14rpx;
  border: 1rpx solid #F0F0F0;
  transition: all 0.2s ease;
}

.detail-item:last-child {
  margin-bottom: 0;
}

.detail-item:active {
  border-color: var(--color-primary, #C41E3A);
}

.detail-label {
  font-size: 22rpx;
  color: #AAAAAA;
  font-weight: 500;
  letter-spacing: 1rpx;
  margin-bottom: 6rpx;
}

.detail-value {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.7;
  display: block;
  margin-top: 4rpx;
}

.line-block {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-primary, #C41E3A);
  display: block;
  letter-spacing: 2rpx;
}

/* ---- 两列详解 ---- */
.detail-columns {
  display: flex;
  gap: 16rpx;
}

.detail-column {
  flex: 1;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid #F0F0F0;
}

.column-title {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--color-primary, #C41E3A);
  display: block;
  margin-bottom: 16rpx;
  text-align: center;
  letter-spacing: 2rpx;
  position: relative;
}

.column-title::after {
  content: '';
  display: block;
  width: 40rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, var(--color-gold, #D4AF37), transparent);
  margin: 8rpx auto 0;
}

/* ---- 解锁区域 ---- */
.share-blur {
  padding: 56rpx 32rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  border: 1rpx solid #F0F0F0;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.blur-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A1A;
  display: block;
  margin-bottom: 12rpx;
}

.blur-hint {
  font-size: 22rpx;
  color: #999999;
  display: block;
  margin-bottom: 28rpx;
  letter-spacing: 1rpx;
}

.share-btn {
  background: linear-gradient(135deg, var(--color-primary, #C41E3A) 0%, #A01830 100%);
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 600;
  padding: 22rpx 56rpx;
  border-radius: 12rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(196,30,58,0.3);
  letter-spacing: 2rpx;
}

.share-btn::after {
  border: none;
}

.share-btn:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(196,30,58,0.3);
}
