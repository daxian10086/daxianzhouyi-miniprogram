/* components/shared-result/index.wxss - 简约现代内容页 */

/* ---------- 结果区域 ---------- */
.shared-result { width: 100%; }

/* ---------- 卦象信息 ---------- */
.hexagram-info {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.hexagram-left { flex: 1; }

.number { 
  font-size: 24rpx; 
  color: #999999; 
  display: block; 
  margin-bottom: 8rpx; 
}

.name { 
  font-size: 48rpx; 
  font-weight: 800; 
  color: #C41E3A; 
  display: block; 
}

.line-name { 
  font-size: 26rpx; 
  color: #666666; 
  margin-top: 8rpx; 
  display: block; 
}

.hexagram-right { 
  display: flex; 
  flex-direction: column; 
  justify-content: center;
  gap: 16rpx;
}

.trigram-item { }

.trigram-label { 
  font-size: 22rpx; 
  color: #BBBBBB; 
  display: block; 
  margin-bottom: 4rpx;
}

.trigram-value { 
  font-size: 28rpx; 
  color: #333333; 
  display: block; 
  font-weight: 500;
}

/* ---------- 选项卡 ---------- */
.tabs {
  display: flex;
  margin: 32rpx 0 24rpx;
}

.tab {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999999;
  background: transparent;
  font-weight: 500;
  position: relative;
}

.tab.active {
  color: #C41E3A;
  font-weight: 700;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #C41E3A;
  border-radius: 2rpx;
}

.tab-content { }

/* ---------- 详情列表 ---------- */
.hexagram-detail { 
  padding: 0; 
}

.detail-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-label { 
  font-size: 24rpx; 
  color: #999999; 
  margin-right: 12rpx; 
}

.detail-value { 
  font-size: 28rpx; 
  color: #1a1a1a; 
  line-height: 1.6;
  display: block;
  margin-top: 8rpx;
}

.line-block { 
  font-size: 32rpx; 
  font-weight: 700; 
  color: #1a1a1a; 
  display: block; 
  margin-bottom: 12rpx;
}

/* ---------- 两列 ---------- */
.detail-columns { 
  display: flex; 
  gap: 32rpx; 
  margin-top: 24rpx; 
}

.detail-column { 
  flex: 1; 
}

.column-title { 
  font-size: 26rpx; 
  font-weight: 700; 
  color: #C41E3A; 
  display: block; 
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #C41E3A;
}

/* ---------- 解锁 ---------- */
.share-blur {
  padding: 48rpx 32rpx;
  margin-top: 24rpx;
  text-align: center;
  background: #FAFAFA;
  border-radius: 16rpx;
}

.blur-text { 
  font-size: 32rpx; 
  font-weight: 600; 
  color: #1a1a1a; 
  display: block; 
  margin-bottom: 12rpx; 
}

.blur-hint { 
  font-size: 24rpx; 
  color: #999999; 
  display: block; 
  margin-bottom: 24rpx; 
}

.share-btn {
  background: #C41E3A;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  padding: 24rpx 64rpx;
  border-radius: 12rpx;
  border: none;
}
.share-btn::after { border: none; }