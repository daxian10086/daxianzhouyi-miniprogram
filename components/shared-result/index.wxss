/* components/shared-result/index.wxss */

/* ---------- 结果区域 ---------- */
.shared-result { width: 100%; }

/* ---------- 卦象信息 ---------- */
.hexagram-info {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.hexagram-left { flex: 1; }

.number { font-size: 22rpx; color: #999999; display: block; margin-bottom: 8rpx; }
.name-row { display: flex; align-items: baseline; gap: 12rpx; }
.name { font-size: 40rpx; font-weight: 800; color: #C41E3A; }
.line-name { font-size: 24rpx; color: #666666; }

.hexagram-right { flex: 1; }

.trigram-item { margin-bottom: 12rpx; }
.trigram-item:last-child { margin-bottom: 0; }
.trigram-label { font-size: 20rpx; color: #BBBBBB; display: block; }
.trigram-value { font-size: 26rpx; color: #333333; display: block; }

/* ---------- 选项卡 ---------- */
.tabs {
  display: flex;
  margin: 24rpx 0;
  border-bottom: 2rpx solid #EEEEEE;
}

.tab {
  flex: 1;
  padding: 16rpx;
  text-align: center;
  font-size: 26rpx;
  color: #999999;
  background: transparent;
  font-weight: 500;
}

.tab.active {
  color: #C41E3A;
  font-weight: 700;
}

.tab-content { margin-top: 16rpx; }

/* ---------- 详情 ---------- */
.hexagram-detail { padding: 0; }

.detail-item {
  padding: 12rpx 0;
  margin-bottom: 8rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.detail-label { font-size: 22rpx; color: #999999; margin-right: 8rpx; }
.detail-value { font-size: 26rpx; color: #1a1a1a; line-height: 1.5; }
.line-block { font-size: 28rpx; font-weight: 700; color: #1a1a1a; display: block; margin-bottom: 8rpx; }

/* ---------- 两列 ---------- */
.detail-columns { display: flex; gap: 24rpx; margin-top: 16rpx; }
.detail-column { flex: 1; }
.column-title { font-size: 24rpx; font-weight: 700; color: #C41E3A; display: block; margin-bottom: 12rpx; }

/* ---------- 解锁 ---------- */
.share-blur {
  padding: 32rpx;
  margin-top: 16rpx;
  text-align: center;
}

.blur-text { font-size: 28rpx; font-weight: 600; color: #1a1a1a; display: block; margin-bottom: 8rpx; }
.blur-hint { font-size: 22rpx; color: #999999; display: block; margin-bottom: 16rpx; }

.share-btn {
  background: #C41E3A;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 600;
  padding: 14rpx 36rpx;
  border-radius: 8rpx;
  border: none;
}
.share-btn::after { border: none; }