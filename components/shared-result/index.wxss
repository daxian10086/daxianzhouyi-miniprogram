/* components/shared-result/index.wxss - 简约UI */

/* ---------- 结果区域 ---------- */
.shared-result { width: 100%; }

/* ---------- 选项卡 ---------- */
.tabs {
  display: flex;
  background: #FAFAFA;
  border-radius: 12rpx;
  overflow: hidden;
}

.tab {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666666;
  background: transparent;
  font-weight: 500;
}

.tab.active {
  background: #C41E3A;
  color: #FFFFFF;
  font-weight: 600;
}

.tab-content {
  margin-top: 24rpx;
}

/* ---------- 详情列表 ---------- */
.hexagram-detail { padding: 0; }

.detail-item {
  background: #FAFAFA;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
}

.detail-label {
  font-size: 22rpx;
  color: #999999;
  font-weight: 500;
  margin-right: 8rpx;
}

.detail-value {
  font-size: 26rpx;
  color: #1a1a1a;
  line-height: 1.6;
}

.line-block {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 8rpx;
}

/* ---------- 两列布局 ---------- */
.detail-columns {
  display: flex;
  gap: 16rpx;
}

.detail-column { flex: 1; }

.column-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #C41E3A;
  display: block;
  text-align: center;
  margin-bottom: 16rpx;
}

/* ---------- 解锁区域 ---------- */
.share-blur {
  background: #FAFAFA;
  border-radius: 16rpx;
  padding: 48rpx;
  margin-top: 24rpx;
  text-align: center;
}

.blur-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
  margin-bottom: 8rpx;
}

.blur-hint {
  font-size: 22rpx;
  color: #999999;
  display: block;
  margin-bottom: 24rpx;
}

.share-btn {
  background: #C41E3A;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 600;
  padding: 20rpx 48rpx;
  border-radius: 12rpx;
  border: none;
}
.share-btn::after { border: none; }