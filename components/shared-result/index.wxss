/* components/shared-result/index.wxss - 完整结果展示共享样式 */

/* ---------- 结果区域 ---------- */
.shared-result {
  width: 100%;
}

/* ---------- 卦象信息 ---------- */
.hexagram-info {
  display: flex;
  padding: 20rpx;
  margin-bottom: 20rpx;
  background: #FAFAFA;
  border-radius: 8rpx;
}

.hexagram-left { flex: 1; }
.hexagram-right { flex: 1; }

.number { font-size: 22rpx; color: #999; }
.name-line { margin-top: 8rpx; }
.name { font-size: 32rpx; font-weight: 700; color: #C41E3A; }
.line { font-size: 24rpx; color: #666; margin-left: 8rpx; }

.trigram-item { margin-bottom: 8rpx; }
.trigram-item .label { font-size: 20rpx; color: #999; display: block; }
.trigram-item .value { font-size: 22rpx; color: #333; }

/* ---------- 选项卡 ---------- */
.tabs {
  display: flex;
  background: #FAFAFA;
  border-radius: 8rpx;
  overflow: hidden;
}

.tab {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666;
  background: transparent;
}

.tab.active {
  background: #C41E3A;
  color: #FFF;
  font-weight: 600;
}

.tab-content { margin-top: 20rpx; }

/* ---------- 详情 ---------- */
.hexagram-detail { padding: 0; }

.detail-item {
  padding: 16rpx;
  margin-bottom: 12rpx;
  background: #FAFAFA;
  border-radius: 6rpx;
}

.detail-label { font-size: 22rpx; color: #999; margin-right: 8rpx; }
.detail-value { font-size: 26rpx; color: #333; line-height: 1.5; }
.line-block { font-size: 28rpx; font-weight: 600; color: #333; display: block; margin-bottom: 8rpx; }

/* ---------- 两列 ---------- */
.detail-columns { display: flex; gap: 12rpx; }
.detail-column { flex: 1; }
.column-title { font-size: 24rpx; color: #C41E3A; font-weight: 600; margin-bottom: 10rpx; display: block; text-align: center; }

/* ---------- 解锁 ---------- */
.share-blur {
  padding: 40rpx;
  background: #FAFAFA;
  border-radius: 8rpx;
  margin-top: 20rpx;
  text-align: center;
}

.blur-text { font-size: 28rpx; color: #333; margin-bottom: 8rpx; display: block; }
.blur-hint { font-size: 22rpx; color: #999; margin-bottom: 20rpx; display: block; }

.share-btn {
  background: #C41E3A;
  color: #FFF;
  font-size: 26rpx;
  padding: 16rpx 40rpx;
  border-radius: 6rpx;
  border: none;
}