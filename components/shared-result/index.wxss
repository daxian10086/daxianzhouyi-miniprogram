/* components/shared-result/index.wxss - 简约有质感设计 */

/* ---------- 结果区域 ---------- */
.shared-result { width: 100%; }

/* ---------- 卦象信息 ---------- */
.hexagram-info {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 28rpx;
  margin-bottom: 20rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  border: 1rpx solid #F0F0F0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.hexagram-left { flex: 1; }

.number { 
  font-size: 22rpx; 
  color: #999999; 
  display: block; 
  margin-bottom: 6rpx; 
}

.name { 
  font-size: 44rpx; 
  font-weight: 800; 
  color: #C41E3A; 
  display: block; 
  letter-spacing: 2rpx;
}

.line-name { 
  font-size: 24rpx; 
  color: #666666; 
  margin-top: 8rpx; 
  display: block; 
}

.hexagram-right { 
  display: flex; 
  flex-direction: column; 
  justify-content: center;
  gap: 12rpx;
}

.trigram-item { }

.trigram-label { 
  font-size: 20rpx; 
  color: #BBBBBB; 
  display: block; 
  margin-bottom: 2rpx;
}

.trigram-value { 
  font-size: 26rpx; 
  color: #333333; 
  display: block; 
  font-weight: 500;
}

/* ---------- 选项卡 ---------- */
.tabs {
  display: flex;
  margin-bottom: 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 6rpx;
  border: 1rpx solid #F0F0F0;
}

.tab {
  flex: 1;
  padding: 18rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666666;
  background: transparent;
  font-weight: 500;
  border-radius: 12rpx;
}

.tab.active {
  background: linear-gradient(135deg, #C41E3A 0%, #A01830 100%);
  color: #FFFFFF;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(196, 30, 58, 0.3);
}

.tab-content { }

/* ---------- 详情列表 ---------- */
.hexagram-detail { 
  padding: 0; 
}

.detail-item {
  padding: 20rpx;
  margin-bottom: 10rpx;
  background: #FFFFFF;
  border-radius: 14rpx;
  border: 1rpx solid #F5F5F5;
}

.detail-item:last-child {
  border-bottom: 1rpx solid #F5F5F5;
}

.detail-label { 
  font-size: 22rpx; 
  color: #999999; 
  margin-right: 10rpx; 
  font-weight: 500;
}

.detail-value { 
  font-size: 26rpx; 
  color: #1a1a1a; 
  line-height: 1.6;
  display: block;
  margin-top: 6rpx;
}

.line-block { 
  font-size: 28rpx; 
  font-weight: 700; 
  color: #C41E3A; 
  display: block; 
  margin-bottom: 10rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #FFF0F0;
}

/* ---------- 两列 ---------- */
.detail-columns { 
  display: flex; 
  gap: 16rpx; 
  margin-top: 16rpx; 
}

.detail-column { 
  flex: 1; 
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1rpx solid #F0F0F0;
}

.column-title { 
  font-size: 24rpx; 
  font-weight: 700; 
  color: #C41E3A; 
  display: block; 
  margin-bottom: 16rpx;
  padding-bottom: 10rpx;
  border-bottom: 2rpx solid #C41E3A;
}

/* ---------- 解锁 ---------- */
.share-blur {
  padding: 48rpx 32rpx;
  margin-top: 20rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  border: 1rpx solid #F0F0F0;
  text-align: center;
}

.blur-text { 
  font-size: 30rpx; 
  font-weight: 600; 
  color: #1a1a1a; 
  display: block; 
  margin-bottom: 10rpx; 
}

.blur-hint { 
  font-size: 22rpx; 
  color: #999999; 
  display: block; 
  margin-bottom: 24rpx; 
}

.share-btn {
  background: linear-gradient(135deg, #C41E3A 0%, #A01830 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  padding: 22rpx 56rpx;
  border-radius: 14rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(196, 30, 58, 0.3);
}
.share-btn::after { border: none; }