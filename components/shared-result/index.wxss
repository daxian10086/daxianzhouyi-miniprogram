/* components/shared-result/index.wxss - 扁平简约风格 */

/* ---------- 结果区域 ---------- */
.shared-result { width: 100%; }

/* ---------- 卦象信息 ---------- */
.hexagram-info {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 60rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  background: #FAFAFA;
  border-radius: 10rpx;
  border: 1rpx solid #EEEEEE;
}

.hexagram-left { }

.number { 
  font-size: 22rpx; 
  color: #999999; 
  display: block; 
  margin-bottom: 4rpx; 
}

.name { 
  font-size: 42rpx; 
  font-weight: 800; 
  color: #C41E3A; 
  display: block; 
  letter-spacing: 2rpx;
}

.line-name { 
  font-size: 24rpx; 
  color: #666666; 
  margin-top: 6rpx; 
  display: block; 
}

.hexagram-right { 
  display: flex; 
  flex-direction: column; 
  justify-content: center;
  gap: 10rpx;
}

.trigram-label { 
  font-size: 20rpx; 
  color: #BBBBBB; 
  display: block; 
  margin-bottom: 2rpx;
}

.trigram-value { 
  font-size: 26rpx; 
  color: #333333; 
  display: block; 
  font-weight: 500;
}

/* ---------- 选项卡 ---------- */
.tabs {
  display: flex;
  margin-bottom: 16rpx;
  background: #FAFAFA;
  border-radius: 10rpx;
  padding: 6rpx;
  border: 1rpx solid #EEEEEE;
}

.tab {
  flex: 1;
  padding: 16rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666666;
  background: transparent;
  font-weight: 500;
  border-radius: 8rpx;
}

.tab.active {
  background: #C41E3A;
  color: #FFFFFF;
  font-weight: 600;
}

.tab-content { }

/* ---------- 详情列表 ---------- */
.hexagram-detail { 
  padding: 0; 
}

.detail-item {
  padding: 18rpx;
  margin-bottom: 10rpx;
  background: #FAFAFA;
  border-radius: 10rpx;
  border: 1rpx solid #EEEEEE;
}

.detail-label { 
  font-size: 22rpx; 
  color: #999999; 
  margin-right: 10rpx; 
  font-weight: 500;
}

.detail-value { 
  font-size: 26rpx; 
  color: #1a1a1a; 
  line-height: 1.6;
  display: block;
  margin-top: 6rpx;
}

.line-block { 
  font-size: 28rpx; 
  font-weight: 700; 
  color: #C41E3A; 
  display: block; 
  margin-bottom: 10rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #FFEEEE;
}

/* ---------- 两列 ---------- */
.detail-columns { 
  display: flex; 
  gap: 14rpx; 
  margin-top: 14rpx; 
}

.detail-column { 
  flex: 1; 
  background: #FAFAFA;
  border-radius: 10rpx;
  padding: 18rpx;
  border: 1rpx solid #EEEEEE;
}

.column-title { 
  font-size: 24rpx; 
  font-weight: 700; 
  color: #C41E3A; 
  display: block; 
  margin-bottom: 14rpx;
  padding-bottom: 10rpx;
  border-bottom: 2rpx solid #C41E3A;
}

/* ---------- 解锁 ---------- */
.share-blur {
  padding: 40rpx 32rpx;
  margin-top: 16rpx;
  background: #FAFAFA;
  border-radius: 10rpx;
  border: 1rpx solid #EEEEEE;
  text-align: center;
}

.blur-text { 
  font-size: 28rpx; 
  font-weight: 600; 
  color: #1a1a1a; 
  display: block; 
  margin-bottom: 8rpx; 
}

.blur-hint { 
  font-size: 22rpx; 
  color: #999999; 
  display: block; 
  margin-bottom: 20rpx; 
}

.share-btn {
  background: #C41E3A;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 600;
  padding: 20rpx 48rpx;
  border-radius: 8rpx;
  border: none;
}
.share-btn::after { border: none; }